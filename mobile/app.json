{
  "expo": {
    "name": "Warranty Vault",
    "slug": "warranty-vault",
    "version": "1.0.0",
    "scheme": "warrantyvault",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#12756b",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.ashley.warrantyvault"
    },
    "android": {
      "package": "com.ashley.warrantyvault",
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-status-bar",
      "expo-sharing",
      [
        "expo-image-picker",
        {
          "cameraPermission": "Warranty Vault uses the camera to photograph receipts and serial-number stickers.",
          "photosPermission": "Warranty Vault needs photo access so you can attach existing receipt photos."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Warranty Vault uses the camera to scan serial stickers, receipts and product photos."
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "68d06ed8-09a3-4465-ae03-cea4a2a481ff"
      }
    },
    "owner": "ashleyd87"
  }
}
