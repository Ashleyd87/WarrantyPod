# Copy to .env for LOCAL development against a deployed backend, or to override
# the auto-detected LAN address. In Expo Go on the same Wi-Fi as your PC you
# usually don't need this — the app finds the Metro host automatically.
#
# For standalone EAS builds, set EXPO_PUBLIC_API_URL in eas.json instead (it is
# baked into the binary at build time).
EXPO_PUBLIC_API_URL="https://your-app.up.railway.app"
