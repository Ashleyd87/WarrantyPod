# Copy to .env and fill in. See DEPLOYMENT.md for where each value comes from.

# --- Database (PostgreSQL) ---
# Railway: add a PostgreSQL service; the app references ${{Postgres.DATABASE_URL}}.
# Locally / for `prisma db push`, use Railway's PUBLIC connection string
# (Postgres service → Connect → Public Network).
DATABASE_URL=""

# --- Auth (better-auth) ---
# Any long random string. Generate one with:  openssl rand -base64 32
BETTER_AUTH_SECRET="change-me-to-a-long-random-string"
# The PUBLIC base URL of the deployed backend (no trailing slash).
# Local dev: http://localhost:3000  ·  Production: https://your-app.up.railway.app
BETTER_AUTH_URL="http://localhost:3000"

# --- File storage ---
# Where uploaded receipt/serial photos are written on disk.
# Local dev: leave as-is. On Railway: create a Volume, mount it (e.g. /data),
# and set this to a folder inside it, e.g. /data/uploads — so files survive
# redeploys.
UPLOAD_DIR="./storage/uploads"

# Optional alternative to a disk/volume: a private Supabase Storage bucket.
# If these are set they take precedence over UPLOAD_DIR. Useful on serverless
# hosts with no persistent disk.
# SUPABASE_URL=""
# SUPABASE_SERVICE_ROLE_KEY=""
# SUPABASE_STORAGE_BUCKET="receipts"

# --- AI extraction (Anthropic) ---
# Leave empty to run in mock mode (extract endpoint returns sample data).
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-5"
